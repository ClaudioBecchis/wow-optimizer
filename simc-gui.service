[Unit]
Description=SimulationCraft GUI
After=xvfb.service

[Service]
Environment=DISPLAY=:1
Environment=QT_QPA_PLATFORM=xcb
Environment=QTWEBENGINE_DISABLE_SANDBOX=1
Environment=HOME=/root
Environment=LANG=it_IT.UTF-8
Environment=LC_ALL=it_IT.UTF-8
WorkingDirectory=/opt/simc/build/qt
ExecStart=/opt/simc/build/qt/SimulationCraft --no-sandbox
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
